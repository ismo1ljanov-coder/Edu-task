// EduTask MVP — Prisma Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  BRANCH_ADMIN
  TEACHER
  STUDENT
}

enum HomeworkLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
}

enum HomeworkResultStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  PAID
  UNPAID
  OVERDUE
}

enum NotificationType {
  HOMEWORK_ASSIGNED
  HOMEWORK_COMPLETED
  NEW_STUDENT
  ANNOUNCEMENT
}

// ---------------------------------------------------------------------------
// CORE MODELS
// ---------------------------------------------------------------------------

// Every login-capable account. Role-specific data lives in Teacher / Student.
model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  passwordHash String
  fullName     String
  role         Role
  isActive     Boolean  @default(true)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])

  teacher       Teacher?
  student       Student?
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([role])
}

model Branch {
  id      String @id @default(uuid())
  name    String
  address String?
  phone   String?

  users     User[]
  teachers  Teacher[]
  students  Student[]
  groups    Group[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Teacher {
  id       String @id @default(uuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  groups    Group[]
  homeworks Homework[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
}

model Student {
  id       String  @id @default(uuid())
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch  @relation(fields: [branchId], references: [id])
  groupId  String?
  group    Group?  @relation(fields: [groupId], references: [id])

  xp      Int @default(0)
  streak  Int @default(0)

  homeworkResults HomeworkResult[]
  payments        Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([groupId])
}

model Group {
  id        String  @id @default(uuid())
  name      String
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id])
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  students  Student[]
  homeworks Homework[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([teacherId])
}

model Homework {
  id          String        @id @default(uuid())
  title       String
  description String?
  level       HomeworkLevel
  startDate   DateTime
  endDate     DateTime

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  groupId   String
  group     Group   @relation(fields: [groupId], references: [id])

  sourceFileName String?
  sourceFileType String? // PDF | DOCX | XLSX | MANUAL

  words   HomeworkWord[]
  results HomeworkResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([teacherId])
}

// English words extracted from the uploaded file (or entered manually),
// consumed later by the "So'zdon" word-game integration.
model HomeworkWord {
  id         String   @id @default(uuid())
  homeworkId String
  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)

  word        String
  translation String?
  order       Int      @default(0)

  createdAt DateTime @default(now())

  @@index([homeworkId])
}

// One row per (student, homework) — tracks progress/status.
model HomeworkResult {
  id         String                @id @default(uuid())
  homeworkId String
  homework   Homework              @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status       HomeworkResultStatus @default(NOT_STARTED)
  progress     Int                  @default(0) // 0-100 %
  correctCount Int                  @default(0)
  totalCount   Int                  @default(0)

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([homeworkId, studentId])
  @@index([studentId])
}

// Payment status is tracked/viewed only — no online payment processing in MVP.
model Payment {
  id        String        @id @default(uuid())
  studentId String
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  month     DateTime
  amount    Decimal       @db.Decimal(12, 2)
  status    PaymentStatus @default(UNPAID)
  paidAt    DateTime?
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@unique([studentId, month])
}

model Notification {
  id     String           @id @default(uuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}
